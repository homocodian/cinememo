{
  "name": "@cinememo/backend",
  "version": "0.0.10",
  "scripts": {
    "dev": "NODE_DEBUG=* NODE_ENV=development bun --watch src/index.ts",
    "build": "NODE_ENV=production bun build --target=bun --sourcemap ./src/index.ts --outdir ./dist",
    "start": "NODE_ENV=production bun ./dist/index.js",
    "test": "bun test",
    "db:migrate": "bun run ./src/db/migrate.ts",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "prettier": "prettier --write .",
    "lint": "eslint --fix .",
    "clean": "rimraf -rf node_modules"
  },
  "dependencies": {
    "@elysiajs/bearer": "^1.4.2",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/cron": "^1.4.1",
    "@lucia-auth/adapter-drizzle": "^1.0.7",
    "@react-email/components": "^1.0.6",
    "@sentry/bun": "^8.55.0",
    "arctic": "^3.7.0",
    "bullmq": "^5.66.7",
    "country-code-lookup": "^0.1.3",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "elysia": "^1.4.22",
    "elysia-ip": "^1.0.10",
    "elysia-rate-limit": "^4.4.2",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.3",
    "lucia": "^3.2.0",
    "oslo": "^1.2.1",
    "resend": "6.8.0",
    "ua-parser-js": "^1.0.41",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/ua-parser-js": "^0.7.39",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "bun-types": "latest",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.39.2",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}